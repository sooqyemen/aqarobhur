rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ✅ دالة التحقق من الأدمن
    // مهم: أبقينا أكثر من بريد حتى لا يتم قفل الرفع على حساب واحد فقط.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email in [
          'aqarobhr@gmail.com',
          'aqarobhur@gmail.com',
          'aboramez965@gmail.com'
        ];
    }

    // ✅ دالة التحقق من نوع وحجم الوسائط (حتى 250 ميجابايت)
    function isAllowedMedia() {
      return request.resource != null
        && request.resource.size < 250 * 1024 * 1024
        && (
          request.resource.contentType == null ||
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('video/.*')
        );
    }

    // =========================================================
    // مجلدات الصور والوسائط الخاصة بالمشروع
    // =========================================================
    match /aqarobhur_images/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isAllowedMedia();
      allow delete: if isAdmin();
    }

    match /fanar_images/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isAllowedMedia();
      allow delete: if isAdmin();
    }

    match /listings/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isAllowedMedia();
      allow delete: if isAdmin();
    }

    match /uploads/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isAllowedMedia();
      allow delete: if isAdmin();
    }

    // إغلاق أي مسارات أخرى غير معرفة
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
