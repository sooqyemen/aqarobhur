rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ✅ دالة للتحقق من أن المستخدم هو الأدمن
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email in [
          'aqarobhr@gmail.com',
          'aqarobhur@gmail.com',
          'aboramez965@gmail.com'
        ];
    }

    // ✅ العرض المسموح للزوار: متاح/محجوز فقط + غير مخفي
    function isPublicListing() {
      return (resource.data.status in ['available', 'reserved'])
        && !(resource.data.hidden == true);
    }

    // =========================================================
    // 1. جداول الطلبات
    // =========================================================
    match /abhur_requests/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /fanar_requests/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // =========================================================
    // 2. جداول العروض
    // =========================================================
    match /abhur_listings/{docId} {
      allow read: if isPublicListing() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /fanar_listings/{docId} {
      allow read: if isPublicListing() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // جدول العروض القديم
    match /listings/{docId} {
      allow read, write: if isAdmin();
    }

    // =========================================================
    // 3. جداول الوارد الذكي والذكاء الاصطناعي
    // =========================================================
    match /fanar_inbox_entries/{docId} {
      allow read, write: if isAdmin();
    }

    match /fanar_extracted_items/{docId} {
      allow read, write: if isAdmin();
    }

    match /abhur_inbox_entries/{docId} {
      allow read, write: if isAdmin();
    }

    match /abhur_extracted_items/{docId} {
      allow read, write: if isAdmin();
    }

    // =========================================================
    // 4. جداول مشاهدات وزيارات الموقع
    // الزائر يكتب العداد فقط، والقراءة للأدمن فقط.
    // مهم: صفحات اليوم محفوظة داخل subcollection باسم pages.
    // =========================================================
    match /abhur_site_stats/{docId} {
      allow create, update: if docId == 'summary';
      allow read, delete: if isAdmin();
    }

    match /abhur_daily_stats/{docId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();

      match /pages/{pageId} {
        allow create, update: if true;
        allow read, delete: if isAdmin();
      }
    }

    match /abhur_page_stats/{docId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    // =========================================================
    // 5. قاعدة عامة: منع الوصول لأي شيء آخر غير معرف أعلاه
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
